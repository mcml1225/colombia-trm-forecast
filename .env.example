# API Configuration
API_BASE_URL=https://suameca.banrep.gov.co
API_TIMEOUT=30
API_RETRY_ATTEMPTS=3

# Model Configuration
LSTM_SEQUENCE_LENGTH=30
TRADITIONAL_MODEL_ORDER=5,1,0
FORECAST_HORIZON=30
RETRAINING_FREQUENCY=daily

# Dashboard Settings
DASHBOARD_REFRESH_INTERVAL=3600
DASHBOARD_THEME=light

# Database (optional)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trm_forecast
DB_USER=admin
DB_PASSWORD=change_me

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/trm_forecast.log

# Notification (optional)
